{
  "name": "@kuzo-mcp/plugin-github",
  "version": "0.0.2",
  "description": "GitHub integration for Kuzo MCP — pull requests, reviews, repositories, branches, files.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seantokuzo/seantokuzo-mcp.git",
    "directory": "packages/plugin-github"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node ../../scripts/check-plugin-manifest-parity.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@kuzo-mcp/types": "^0.0.1"
  },
  "devDependencies": {
    "@kuzo-mcp/types": "workspace:^"
  },
  "kuzoPlugin": {
    "name": "github",
    "permissionModel": 1,
    "entry": "./dist/index.js",
    "minCoreVersion": "^0.0.1",
    "capabilities": [
      {
        "kind": "credentials",
        "env": "GITHUB_TOKEN",
        "access": "client",
        "reason": "Authenticates with the GitHub API for all operations"
      },
      {
        "kind": "network",
        "domain": "api.github.com",
        "reason": "All GitHub API calls"
      },
      {
        "kind": "cross-plugin",
        "target": "git-context",
        "reason": "Auto-detect repository and branch from local git"
      }
    ],
    "optionalCapabilities": [
      {
        "kind": "credentials",
        "env": "GITHUB_USERNAME",
        "access": "raw",
        "reason": "Default owner for short repo names (e.g., 'myrepo' → 'owner/myrepo')"
      }
    ]
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}

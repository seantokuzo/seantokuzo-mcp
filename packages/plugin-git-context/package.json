{
  "name": "@kuzo-mcp/plugin-git-context",
  "version": "0.0.2",
  "description": "Git context plugin for Kuzo MCP — detects repo, branch, and working tree state.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seantokuzo/seantokuzo-mcp.git",
    "directory": "packages/plugin-git-context"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node ../../scripts/check-plugin-manifest-parity.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@kuzo-mcp/types": "^0.0.1"
  },
  "devDependencies": {
    "@kuzo-mcp/types": "workspace:^"
  },
  "kuzoPlugin": {
    "name": "git-context",
    "permissionModel": 1,
    "entry": "./dist/index.js",
    "minCoreVersion": "^0.0.1",
    "capabilities": [
      {
        "kind": "filesystem",
        "access": "read",
        "path": "$CWD/.git/**",
        "reason": "Read git metadata to detect repo, branch, and working tree state"
      },
      {
        "kind": "system",
        "operation": "exec",
        "command": "git",
        "reason": "Run git commands for branch, status, and remote detection"
      }
    ]
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}

{
  "name": "@kuzo-mcp/cli",
  "version": "0.0.2",
  "description": "Interactive CLI for Kuzo MCP — PR automation, code review, Jira, consent, audit.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seantokuzo/seantokuzo-mcp.git",
    "directory": "packages/cli"
  },
  "bin": {
    "kuzo": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kuzo-mcp/core": "workspace:^",
    "@kuzo-mcp/plugin-github": "workspace:^",
    "@kuzo-mcp/plugin-jira": "workspace:^",
    "@kuzo-mcp/types": "workspace:^",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "figlet": "^1.7.0",
    "gradient-string": "^3.0.0",
    "inquirer": "^10.1.8",
    "nanospinner": "^1.1.0",
    "pacote": "^21.5.0",
    "signal-exit": "^4.1.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/pacote": "^11.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}

{
  "name": "seantokuzo-mcp",
  "version": "1.0.0",
  "description": "🔥 Kuzo MCP - plugin-based personal MCP server",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "clean": "pnpm -r run clean && rm -f tsconfig.tsbuildinfo",
    "start:mcp": "node packages/core/dist/server.js",
    "dev:cli": "pnpm --filter @kuzo-mcp/cli run dev",
    "cli": "pnpm --filter @kuzo-mcp/cli run dev",
    "test": "pnpm run test:parity",
    "test:parity": "node scripts/test-install-parity.mjs",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "mcp",
    "github",
    "jira",
    "cli",
    "plugin"
  ],
  "author": "Sean Tokuzo",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.5.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "hono"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}

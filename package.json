{
  "name": "seantokuzo-mcp",
  "version": "1.0.0",
  "description": "🔥 Kuzo MCP - plugin-based personal MCP server",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -b && pnpm run check:manifest",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "check:manifest": "pnpm -r --filter \"./packages/plugin-*\" exec node ../../scripts/check-plugin-manifest-parity.mjs",
    "clean": "pnpm -r run clean && rm -f tsconfig.tsbuildinfo",
    "start:mcp": "node packages/core/dist/server.js",
    "dev:cli": "pnpm --filter @kuzo-mcp/cli run dev",
    "cli": "pnpm --filter @kuzo-mcp/cli run dev",
    "test": "pnpm run test:parity && pnpm run test:provenance && pnpm run test:credentials && pnpm run test:audit && pnpm run test:cli",
    "test:parity": "node scripts/test-install-parity.mjs",
    "test:provenance": "pnpm -s build && node scripts/smoke-provenance.mjs",
    "test:credentials": "KUZO_TEST=1 node --import tsx --test packages/core/src/credentials/cipher.test.ts packages/core/src/credentials/key-provider.test.ts packages/core/src/credentials/store.test.ts packages/core/src/credentials/source.test.ts packages/core/src/credentials/env-overrides.test.ts packages/core/src/credentials/env-namespace.test.ts packages/core/src/credentials/debounce.test.ts packages/core/src/credentials.test.ts packages/core/src/serve-summary.test.ts",
    "test:audit": "KUZO_TEST=1 node --import tsx --test packages/core/src/audit-ipc.test.ts",
    "test:cli": "pnpm -s build && KUZO_TEST=1 node --import tsx --test packages/cli/src/lock.test.ts packages/cli/src/commands/credentials/errors.test.ts packages/cli/src/commands/credentials/migrate-redact.test.ts packages/cli/src/commands/credentials/migrate-fs.test.ts packages/cli/src/commands/credentials/migrate-discovery.test.ts packages/cli/src/commands/credentials/migrate.test.ts",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "mcp",
    "github",
    "jira",
    "cli",
    "plugin"
  ],
  "author": "Sean Tokuzo",
  "license": "MIT",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.5.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "hono"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}

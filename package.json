{
  "name": "seantokuzo-mcp",
  "version": "1.0.0",
  "description": "🔥 Kuzo MCP - PR automation, code reviews & JIRA integration",
  "type": "module",
  "bin": {
    "kuzo": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev:cli": "tsx src/cli/index.ts",
    "start:mcp": "node dist/core/server.js",
    "cli": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc -b"
  },
  "keywords": [
    "mcp",
    "github",
    "cli",
    "automation",
    "pull-request"
  ],
  "author": "Sean Tokuzo",
  "license": "MIT",
  "dependencies": {
    "@kuzo-mcp/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^21.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "figlet": "^1.7.0",
    "gradient-string": "^3.0.0",
    "inquirer": "^10.1.8",
    "nanospinner": "^1.1.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.5.0",
    "eslint": "^10.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["hono"]
    },
    "onlyBuiltDependencies": ["esbuild"]
  }
}

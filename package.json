{
  "name": "seantokuzo-mcp",
  "version": "1.0.0",
  "description": "🔥 Sean's MCP Server - Making PRs great again, one commit at a time",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sean-mcp": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp/server.js",
    "start:webhook": "node dist/server.js",
    "cli": "tsx src/cli/index.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "github",
    "cli",
    "automation",
    "pull-request"
  ],
  "author": "Sean Tokuzo",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^21.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "figlet": "^1.7.0",
    "gradient-string": "^3.0.0",
    "inquirer": "^10.1.8",
    "nanospinner": "^1.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/figlet": "^1.5.8",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

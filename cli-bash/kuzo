    echo -e "${GRAD1}██╔═██╗ ${GRAD2}██║   ██║${GRAD3} ███╔╝  ${GRAD1}██║   ██║${NC}"
    echo -e "${GRAD1}██║  ██╗${GRAD2}╚██████╔╝${GRAD3}███████╗${GRAD1}╚██████╔╝${NC}"

# ============================================
# 🚀 Main Entry Point
# ============================================

main() {
    check_requirements
    
    local command="${1:-}"
    local subcommand="${2:-}"
    
    case "$command" in
        "")
            interactive_menu
            ;;
        "-h"|"--help"|"help")
            show_help
            ;;
        "-v"|"--version"|"version")
            echo "Kuzo MCP Bash CLI v1.0.0 (pure bash, no dependencies)"
            ;;
        "setup")
            cmd_setup
            show_goodbye
            ;;
        "config")
            case "$subcommand" in
                ""|"status") cmd_config_status ;;
                "setup") cmd_setup; show_goodbye ;;
                *) show_error "Unknown config command: $subcommand" ;;
            esac
            ;;
        "pr")
            case "$subcommand" in
                "create"|"new") cmd_pr_create; show_goodbye ;;
                "update"|"edit") cmd_pr_update; show_goodbye ;;
                "list"|"ls"|"") cmd_pr_list; show_goodbye ;;
                *) show_error "Unknown pr command: $subcommand" ;;
            esac
            ;;
        "repo")
            case "$subcommand" in
                "create"|"new") cmd_repo_create; show_goodbye ;;
                "list"|"ls"|"") cmd_repo_list; show_goodbye ;;
                *) show_error "Unknown repo command: $subcommand" ;;
            esac
            ;;
        "jira")
            case "$subcommand" in
                "mine"|"tickets"|"") cmd_jira_mine; show_goodbye ;;
                "move") cmd_jira_move "${3:-}"; show_goodbye ;;
                "comment"|"c") cmd_jira_comment; show_goodbye ;;
                "search"|"s") cmd_jira_search; show_goodbye ;;
                *) show_error "Unknown jira command: $subcommand" ;;
            esac
            ;;
        *)
            show_error "Unknown command: $command"
            echo ""
            show_help
            ;;
    esac
}

main "$@"

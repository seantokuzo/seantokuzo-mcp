show_box() {
    local title="$1"
    local content="$2"
    local color="${3:-$CYAN}"
    
    echo -e "${color}╔════════════════════════════════════════════════════════╗${NC}"
    echo -e "${color}║${NC} ${BOLD}${title}${NC}"
    echo -e "${color}╟────────────────────────────────────────────────────────╢${NC}"
    while IFS= read -r line; do
        printf "${color}║${NC} %-54s ${color}║${NC}\n" "$line"
    done <<< "$content"
    echo -e "${color}╚════════════════════════════════════════════════════════╝${NC}"
}

show_success() {
    echo -e "${GREEN}✓${NC} ${BOLD}$1${NC}"
    [[ -n "${2:-}" ]] && echo -e "  ${DIM}$2${NC}"
}

show_error() {
    echo -e "${RED}✗${NC} ${BOLD_RED}$1${NC}" >&2
    [[ -n "${2:-}" ]] && echo -e "  ${DIM}$2${NC}" >&2
}

show_warning() {
    echo -e "${YELLOW}⚠${NC} ${BOLD}$1${NC}"
    [[ -n "${2:-}" ]] && echo -e "  ${DIM}$2${NC}"
}

show_info() {
    echo -e "${BLUE}ℹ${NC} ${BOLD}$1${NC}"
    [[ -n "${2:-}" ]] && echo -e "  ${DIM}$2${NC}"
}

show_goodbye() {
    local messages=(
        "May your PRs be merged swiftly! 🚀"
        "Keep shipping! 📦"
        "Code on, friend! 💻"
        "See you in the next commit! 👋"
        "Happy coding! ✨"
        "PR you later! 🔀"
        "Git outta here! (in a good way) 😄"
    )
    # Use RANDOM with modulo for bash 3 compatibility
    local idx=$((RANDOM % ${#messages[@]}))
    local random_msg="${messages[$idx]}"
    
    echo ""
    echo -e "${DIM}─────────────────────────────────────────${NC}"
    echo -e "${GRAD2}$random_msg${NC}"
    echo -e "${DIM}─────────────────────────────────────────${NC}"

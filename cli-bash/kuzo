#!/usr/bin/env bash
# ╔═══════════════════════════════════════════════════════════════════╗
# ║                    🚀 KUZO MCP - Bash CLI                          ║
# ║         PR Automation & GitHub/JIRA Integration Tool               ║
# ╚═══════════════════════════════════════════════════════════════════╝
#
# A pure bash implementation of the Kuzo MCP CLI.
# NO DEPENDENCIES - just bash and curl!
#
# Usage: ./kuzo [command] [subcommand] [options]
#        ./kuzo                  # Interactive mode
#        ./kuzo pr create        # Create a PR
#        ./kuzo jira mine        # View my tickets
#
# Requirements: bash 3.2+, curl (that's it!)

# Don't use set -e - it causes issues with interactive menus

# ============================================
# 📍 Configuration
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Load .env file from project root
if [[ -f "$PROJECT_ROOT/.env" ]]; then
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip comments and empty lines
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$line" ]] && continue
        # Skip lines without =
        [[ ! "$line" =~ = ]] && continue
        # Only process valid variable assignments
        if [[ "$line" =~ ^[A-Za-z_][A-Za-z0-9_]*= ]]; then
            # Extract key and value
            _key="${line%%=*}"
            _value="${line#*=}"
            # Remove surrounding quotes if present
            _value="${_value%\"}"
            _value="${_value#\"}"
            _value="${_value%\'}"
            _value="${_value#\'}"
            # Export the variable
            export "$_key=$_value"
        fi
    done < "$PROJECT_ROOT/.env"
fi

# ============================================
# 🎨 Colors & Styling
# ============================================

# Check if terminal supports colors
if [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]]; then
    COLORS_SUPPORTED=true
else
    COLORS_SUPPORTED=false
fi

# ANSI color codes
if $COLORS_SUPPORTED; then
    NC='\033[0m'
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    MAGENTA='\033[0;35m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    BOLD_RED='\033[1;31m'
    BOLD_CYAN='\033[1;36m'
    BOLD_MAGENTA='\033[1;35m'
    DIM='\033[2m'
    GRAD1='\033[38;5;204m'
    GRAD2='\033[38;5;43m'
    GRAD3='\033[38;5;39m'
else
    NC='' RED='' GREEN='' YELLOW='' BLUE='' MAGENTA='' CYAN=''
    BOLD='' BOLD_RED='' BOLD_CYAN='' BOLD_MAGENTA='' DIM=''
    GRAD1='' GRAD2='' GRAD3=''
fi

# ============================================
# 🔧 Pure Bash JSON Parser
# ============================================

# Extract a simple string value from JSON: json_get '{"key":"value"}' 'key' -> value
json_get() {
    local json="$1"
    local key="$2"
    # Handle both "key": "value" and "key": value (for numbers/bools)
    echo "$json" | grep -o "\"$key\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | head -1 | sed 's/.*: *"\([^"]*\)".*/\1/' || \
    echo "$json" | grep -o "\"$key\"[[:space:]]*:[[:space:]]*[^,}\]]*" | head -1 | sed 's/.*: *//' | tr -d ' '
}

# Extract a number value from JSON
json_get_num() {
    local json="$1"
    local key="$2"
    echo "$json" | grep -o "\"$key\"[[:space:]]*:[[:space:]]*[0-9]*" | head -1 | sed 's/.*: *//'
}

# Extract boolean value
json_get_bool() {
    local json="$1"
    local key="$2"
    echo "$json" | grep -o "\"$key\"[[:space:]]*:[[:space:]]*\(true\|false\)" | head -1 | sed 's/.*: *//'
}

# Extract nested object value: json_get_nested '{"a":{"b":"c"}}' 'a' 'b' -> c
json_get_nested() {
    local json="$1"
    local key1="$2"
    local key2="$3"
    # First extract the nested object, then get the key from it
    local nested
    nested=$(echo "$json" | grep -o "\"$key1\"[[:space:]]*:[[:space:]]*{[^}]*}" | head -1 | sed "s/\"$key1\"[[:space:]]*:[[:space:]]*//")
    json_get "$nested" "$key2"
}

# Count array items (rough estimate based on pattern)
json_array_length() {
    local json="$1"
    # Count opening braces for objects in array, or count specific patterns
    echo "$json" | grep -o '"number"' | wc -l | tr -d ' '
}

# Check if JSON response is an error
json_is_error() {
    local json="$1"
    echo "$json" | grep -q '"message"' && ! echo "$json" | grep -q '"number"'
}

# Extract array items - outputs one item per line with key fields separated by |
# Usage: json_array_extract "$json" "number" "state" "title"
json_array_extract() {
    local json="$1"
    shift
    local keys=("$@")
    
    # Remove newlines and split by },{ to get individual objects
    local cleaned
    cleaned=$(echo "$json" | tr '\n' ' ' | sed 's/\[//g' | sed 's/\]//g')
    
    # Split into objects and process each
    echo "$cleaned" | grep -o '{[^{]*}' | while read -r obj; do
        local line=""
        for key in "${keys[@]}"; do
            local val
            if [[ "$key" == *"."* ]]; then
                # Nested key like "user.login"
                local k1="${key%%.*}"
                local k2="${key#*.}"
                val=$(json_get_nested "$obj" "$k1" "$k2")
            else
                val=$(json_get "$obj" "$key")
            fi
            [[ -n "$line" ]] && line="$line|"
            line="$line$val"
        done
        echo "$line"
    done
}

# URL encode a string
url_encode() {
    local string="$1"
    local strlen=${#string}
    local encoded=""
    local pos c o
    
    for (( pos=0 ; pos<strlen ; pos++ )); do
        c=${string:$pos:1}
        case "$c" in
            [-_.~a-zA-Z0-9] ) o="$c" ;;
            * ) printf -v o '%%%02X' "'$c" ;;
        esac
        encoded+="$o"
    done
    echo "$encoded"
}

# Create JSON payload (escapes strings properly)
json_escape() {
    local str="$1"
    str="${str//\\/\\\\}"
    str="${str//\"/\\\"}"
    str="${str//$'\n'/\\n}"
    str="${str//$'\r'/\\r}"
    str="${str//$'\t'/\\t}"
    echo "$str"
}


# ╔═══════════════════════════════════════════════════════════════════╗
# ║                    🚀 Sean-MCP Configuration                       ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────────
# 🐙 GitHub Configuration
# ─────────────────────────────────────────────────────────────────────

# Your GitHub Personal Access Token
# Get one at: https://github.com/settings/tokens
# Required scopes: repo, read:user
# For GitHub Enterprise: https://github.yourcompany.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub username (used for default author identification)
GITHUB_USERNAME=seantokuzo

# GitHub Organization (optional)
# If you work within an org, set this to skip the "which org?" prompt
# Leave blank for personal repos
GITHUB_ORG=

# ─────────────────────────────────────────────────────────────────────
# 🎫 JIRA Configuration (Optional - only needed for JIRA features)
# ─────────────────────────────────────────────────────────────────────

# Your JIRA instance hostname (without https://)
# Cloud example: mycompany.atlassian.net
# Server/Data Center example: jira.mycompany.com
JIRA_HOST=mycompany.atlassian.net

# Your JIRA account email
JIRA_EMAIL=you@company.com

# JIRA API Token (NOT your password!)
# Cloud: https://id.atlassian.com/manage-profile/security/api-tokens
# Server: Use your password or create a PAT in JIRA settings
JIRA_API_TOKEN=ATATT3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────
# 🌐 Webhook Server (Optional - for automated workflows)
# ─────────────────────────────────────────────────────────────────────
# The webhook server listens for GitHub events (PR opened, merged, etc.)
# Useful for: auto-updating JIRA tickets when PRs merge, notifications, etc.
# You'd configure this URL in your GitHub repo's webhook settings.
# Most people won't need this - the CLI works fine without it.
WEBHOOK_PORT=3847
WEBHOOK_SECRET=generate_a_random_secret_here

# ─────────────────────────────────────────────────────────────────────
# 🎨 CLI Preferences
# ─────────────────────────────────────────────────────────────────────

# CLI personality affects messages and vibes
# Options: professional, chaotic, zen
CLI_PERSONALITY=chaotic

# Preferred editor for PR descriptions and other multi-line input
# Use --wait flag so CLI waits for you to close the file
# Examples: "code --wait", "vim", "nano", "subl -w"
# Falls back to VISUAL env var, then nano if not set
EDITOR=code --wait

# ─────────────────────────────────────────────────────────────────────
# 📝 Default PR Settings
# ─────────────────────────────────────────────────────────────────────

# Default base branch for PRs (usually main or master)
DEFAULT_PR_BASE_BRANCH=main

# Create PRs as drafts by default? (true/false)
DEFAULT_PR_DRAFT=false